# ─────────────────────────────────────────────────────────────────────
# FRONTEND env vars (Vercel)
# ─────────────────────────────────────────────────────────────────────
# When deployed to Vercel, the frontend lives on a different origin
# than the backend. VITE_API_URL tells the frontend where to find API.
#
# Vercel rewrites in vercel.json proxy /api/* to Render automatically,
# so this can stay empty when relying on Vercel rewrites. Set explicitly
# only if proxying via Vercel is disabled or you need direct calls.
VITE_API_URL=

# Sentry DSN for frontend error tracking (free tier 5K errors/month)
# Sign up at sentry.io → create project → copy DSN here.
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────
# BACKEND env vars (Render)
# ─────────────────────────────────────────────────────────────────────
# Kite Connect (broker integration)
KITE_API_KEY=
KITE_API_SECRET=
KITE_REQUEST_TOKEN=

# Anthropic (Claude AI for narrative generation)
ANTHROPIC_API_KEY=

# Sentry DSN for backend (separate project from frontend)
SENTRY_DSN=

# Allow PnL trades on expiry days (default OFF — theta crush protection)
# Set to 1 to override the default block.
ALLOW_PNL_ON_EXPIRY=

# Additional CORS origins (comma-separated)
# e.g., ALLOWED_ORIGINS=https://yourdomain.com,https://staging.yourdomain.com
ALLOWED_ORIGINS=

# Render auto-sets these — DON'T override
# RENDER=true (auto)
# PORT=10000 (auto)
# PYTHON_VERSION=3.11.0 (set in render.yaml)
